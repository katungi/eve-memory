{
  "name": "eve-memory",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Cross-session memory layer for the Vercel eve agent framework",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katungi/eve-memory.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "executableFiles": ["./dist/esm/bin.js"]
  },
  "bin": {
    "eve-memory": "./dist/esm/bin.js"
  },
  "scripts": {
    "codegen": "build-utils prepare-v2",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "peerDependencies": {
    "ai": "^7.0.0",
    "eve": ">=0.13.0",
    "zod": "^3 || ^4"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "effect": {
    "generateExports": {
      "include": [
        "adapters.ts"
      ]
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/dts/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./adapters": {
      "types": "./dist/dts/adapters.d.ts",
      "import": "./dist/esm/adapters.js",
      "default": "./dist/cjs/adapters.js"
    }
  },
  "devDependencies": {
    "ai": "^7.0.14",
    "eve": "^0.19.0",
    "zod": "^4.4.3"
  }
}
